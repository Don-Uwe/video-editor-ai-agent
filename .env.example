# Google AI API key (required for Gemini agents)
# Get yours at https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_api_key_here

# Application
AVE_LOG_LEVEL=INFO
AVE_OUTPUT_DIR=output
AVE_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
AVE_BROWSE_ROOTS=~

# Redis (optional — enables job snapshot persistence and Studio cache)
REDIS_ENABLED=true
REDIS_URL=redis://127.0.0.1:6379
REDIS_KEY_PREFIX=ave:
REDIS_MAX_RETRIES=3
REDIS_CONNECT_TIMEOUT_MS=5000
REDIS_LAZY_CONNECT=true

# Next.js Studio (optional override)
NEXT_PUBLIC_API_URL=
